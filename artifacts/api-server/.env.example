# ============================================================================
# @workspace/api-server — environment variables
# ============================================================================

# Required
PORT=3000
DATABASE_URL=postgres://user:password@host:5432/deerpark
INGEST_SECRET=change-me-openssl-rand-hex-32

# Headline ingestion
HEADLINE_INGEST_INTERVAL_MIN=15
# Set to 1 to disable the in-process scheduler (useful for tests or one-shot runs)
DISABLE_HEADLINE_SCHEDULER=

# Per-source feed URLs. Anthropic / OpenAI have no stable public RSS; leave blank
# until you supply a scraper endpoint or mirror.
ANTHROPIC_FEED_URL=
OPENAI_FEED_URL=
GOOGLE_AI_FEED_URL=https://blog.google/technology/ai/rss/
NVIDIA_FEED_URL=https://blogs.nvidia.com/feed/
AWS_ML_FEED_URL=https://aws.amazon.com/blogs/machine-learning/feed/
HN_QUERY_URL=https://hn.algolia.com/api/v1/search_by_date?tags=story&query=AI&hitsPerPage=30
HF_PAPERS_URL=https://huggingface.co/api/daily_papers

# Phase B+ (not yet wired — placeholders for the writer agent / admin auth)
# ANTHROPIC_API_KEY=
# ADMIN_USER=
# ADMIN_PASS_HASH=
