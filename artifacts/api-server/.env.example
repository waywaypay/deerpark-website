# ============================================================================
# @workspace/api-server — environment variables
# ============================================================================

# Required
PORT=3000
DATABASE_URL=postgres://user:password@host:5432/deerpark
INGEST_SECRET=change-me-openssl-rand-hex-32

# Headline ingestion
HEADLINE_INGEST_INTERVAL_MIN=15
# Set to 1 to disable the in-process scheduler (useful for tests or one-shot runs)
DISABLE_HEADLINE_SCHEDULER=

# Per-source feed URLs. Anthropic / OpenAI have no stable public RSS; leave blank
# until you supply a scraper endpoint or mirror.
ANTHROPIC_FEED_URL=
OPENAI_FEED_URL=
GOOGLE_AI_FEED_URL=https://blog.google/technology/ai/rss/
NVIDIA_FEED_URL=https://blogs.nvidia.com/feed/
AWS_ML_FEED_URL=https://aws.amazon.com/blogs/machine-learning/feed/
HN_QUERY_URL=https://hn.algolia.com/api/v1/search_by_date?tags=story&query=AI&hitsPerPage=30
HF_PAPERS_URL=https://huggingface.co/api/daily_papers

# Phase B+ (not yet wired — placeholders for the writer agent / admin auth)
# ANTHROPIC_API_KEY=
# ADMIN_USER=
# ADMIN_PASS_HASH=

# ----------------------------------------------------------------------------
# SMS scorecard concierge (artifacts/api-server/src/routes/sms.ts)
# ----------------------------------------------------------------------------
# Auth token from your Twilio account. Used to verify webhook signatures
# AND to authenticate outbound REST API calls for async replies.
# Find it at: https://console.twilio.com → Account → API keys & tokens.
# REQUIRED in production. If unset and TWILIO_SKIP_VERIFY!=1, the webhook
# returns 503 and refuses to process anything.
TWILIO_AUTH_TOKEN=

# Account SID (starts with AC...) from the same Account Info panel as the
# auth token. Required for sending async replies via Twilio's REST API.
TWILIO_ACCOUNT_SID=

# The toll-free number we send replies *from*, in E.164 (e.g. +18669317144).
# Must be a number on the same Twilio account.
TWILIO_FROM_NUMBER=

# Set to "1" to skip signature verification — dev/local only. NEVER in prod.
TWILIO_SKIP_VERIFY=

# OpenAI-compatible LLM client used by the SMS bot. Reuses the same vars as
# the writer agent — set them once.
LLM_API_KEY=
LLM_BASE_URL=https://api.venice.ai/api/v1
SMS_LLM_MODEL=claude-sonnet-4-5

# Bearer token for /api/admin/sms/* eval endpoints. Generate with:
#   openssl rand -hex 32
ADMIN_SECRET=

# ----------------------------------------------------------------------------
# Daily digest (artifacts/api-server/src/lib/daily-digest.ts)
# ----------------------------------------------------------------------------
# Picks the best post from the last 24h every day at the configured UTC time
# and emails it directly to the active subscribers in the local DB (the form
# at /dispatch). Per-recipient send with personalized unsubscribe links.

# The verified-domain sender Resend will use. Must be a domain you've added
# + verified in Resend (https://resend.com/domains).
DAILY_DIGEST_FROM_EMAIL=

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Public origin for unsubscribe links. Defaults to https://deerpark-api.fly.dev.
PUBLIC_API_BASE_URL=

# When to fire each day. Defaults: 13:00 UTC = 9:00 AM ET (EDT).
# During EST (winter), 14:00 UTC = 9:00 AM ET. Set explicitly if it matters.
DAILY_DIGEST_HOUR_UTC=13
DAILY_DIGEST_MINUTE_UTC=0

# Set to 1 to disable the in-process scheduler.
DISABLE_DAILY_DIGEST=
