# ============================================================================
# @workspace/deerpark-web — environment variables
# ============================================================================
#
# Vite exposes any variable prefixed with VITE_ to the client bundle. NEVER
# put secrets here — anything in this file ships to every visitor's browser.

# SMS scorecard concierge — full E.164 phone number, e.g. +15551234567.
# When unset (or invalid), all SMS CTAs (hero subline, lead-capture link,
# "Text" FAB) render nothing. That's the kill switch if Twilio breaks or
# we want to ship copy work before the number is provisioned.
VITE_SMS_NUMBER=
