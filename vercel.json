{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile --filter @workspace/deerpark-web...",
  "buildCommand": "pnpm --filter @workspace/deerpark-web build",
  "outputDirectory": "artifacts/deerpark-web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://deerpark-api.fly.dev/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
